# TeX temporary files
#
# comment out files you wish to include into the repository
# (e.g. .pdf if you compile on the server)
#
# online generator: https://www.toptal.com/developers/gitignore

## Core latex/pdflatex auxiliary files
*.aux
*.lof
*.log
*.lot
*.fls
*.out
*.toc
*.fmt
*.fot
*.cb
*.cb2
# If using glossaries-extra, uncomment the following line (will ignore makeindex's style files!):
#*.ist

## Intermediate documents
*.dvi
*.xdv
*.ps
*.pdf
# comment out following line to ignore all eps files (e.g. if you have only
# generated eps files, but keep the sources)
# *.eps

## LaTeX generated files
#
# Files generated by the bibliography management tool
*.bbl
*.blg

# Files generated by makeindex
*.idx
*.ind
*.ilg
# If using glossaries, uncomment following lines (gls, gls-?? and ist files are
# makeindex style files):
# *.gls
# *.gls-??
# *.ist

# Files generated by xindy
*.idx.???
*.ind.???
*.ilg.???
*.xdy

# Files generated by the nomencl package
*.nlo
*.nls

# Files generated by the changes package
*.aps

# Files generated by the synctex package
*.synctex
*.synctex(busy)

# Files generated by the asymptote package
*.asy
# Asymptote intermediate files (may not be generated depending on the version)
*.prc
*.tns

# Files generated by the sagetex package
*.sagetex.sage
*.sagetex.sc
*.sagetex.wlog
*.mw

# Files generated by the media9 package
*.vrb
*.settings

# Files generated by the mintikz package
*-minted-*.tex

# Files generated by the minted package
_minted-*

# Files generated by the pythontex package
*.pytxcode
*.pytxmcr
*.pytxlog

# Files generated by the auto-pst-pdf package
*-auto-pst-pdf.pdf
*-auto-pst-pdf.log

# Files generated by the epstopdf package
*.epstopdf-cache

# Files generated by the lwarp package
*-lwarp.lua
*-lwarp-*.html
*-lwarp-*.css
*-lwarp-*.js

